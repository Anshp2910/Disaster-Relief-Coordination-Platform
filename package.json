{
  "name": "disaster-relief-cooperation-platform",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "server": "npm --prefix server run dev",
    "client": "npm --prefix client run dev",
    "dev": "npm-run-all -p server client",
    "test": "npm-run-all test:server test:client",
    "test:server": "npm --prefix server run test",
    "test:client": "npm --prefix client run test",
    "seed:demo": "npm --prefix server run seed:demo",
    "build": "npm --prefix client run build",
    "start": "node server/src/index.js"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "mongodb-memory-server": "^11.2.0",
    "npm-run-all": "^4.1.5"
  }
}
