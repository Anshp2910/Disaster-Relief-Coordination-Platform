{
  "name": "disaster-relief-cooperation-platform",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "server": "npm --prefix server run dev",
    "client": "npm --prefix client run dev",
    "dev": "npm-run-all -p server client",
