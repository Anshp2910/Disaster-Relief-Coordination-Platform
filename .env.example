# =============================================================================
# Disaster Relief Coordination Platform - Environment Configuration
# =============================================================================
# WARNING: Never commit real secrets to version control. This file is a template.
# Copy to .env and fill in your actual values.
# =============================================================================

MONGODB_URI=mongodb://localhost:27017/disaster_relief
JWT_SECRET=change_me_to_a_long_random_secret_at_least_32_chars
PORT=5001
CLIENT_URL=http://localhost:5173

# Admin seed (creates/promotes admin on server start)
ADMIN_EMAIL=admin@relief.gov.in
ADMIN_PASSWORD=change_me_to_strong_password
ADMIN_DISPLAY_NAME=Administrator

# Email (Resend) — required for password reset emails
# Get an API key at https://resend.com/api-keys
# In development, when RESEND_API_KEY is not set, reset URLs are shown in the server console.
RESEND_API_KEY=
# Optional: sender email, e.g. "Disaster Relief <noreply@yourdomain.com>"
RESEND_FROM=

# Google OAuth 2.0 — for social login via Google
# Create OAuth credentials at https://console.cloud.google.com/apis/credentials
# Add the Authorized redirect URI: http://localhost:5001/api/auth/google/callback (dev)
#                                                   https://yourdomain.com/api/auth/google/callback (prod)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth — for social login via GitHub
# Register an OAuth app at https://github.com/settings/developers
# Set the Authorization callback URL: http://localhost:5001/api/auth/github/callback (dev)
#                                                        https://yourdomain.com/api/auth/github/callback (prod)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Optional: App name used in email templates
APP_NAME=Disaster Relief Platform

# Optional: Set to production in deployed environments
NODE_ENV=development

# Optional: Set to the current commit SHA for version tracking
COMMIT_SHA=

# Optional: Set to a unique build identifier
BUILD_VERSION=
